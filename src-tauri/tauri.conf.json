{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "gem",
  "version": "1.0.0",
  "identifier": "com.jesus.gem",
  "build": {
    "frontendDist": "../frontend"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "GEM",
        "width": 480,
        "height": 800,
        "minWidth": 380,
        "minHeight": 600,
        "resizable": true,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": false,
        "shadow": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}